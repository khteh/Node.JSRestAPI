    "@types/config": "^3.3.5",
    "@types/node": "^25.8.0",
    "nodemon": "^3.1.14",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
